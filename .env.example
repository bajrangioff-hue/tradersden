# ═══════════════════════════════════════════════════════════
# TradePro Root — Global / Docker-Compose Variables
# ═══════════════════════════════════════════════════════════
# Copy to .env before running docker-compose up.
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

# Environment: development | staging | production
APP_ENV=development

# Backend database URL (injected into backend container)
DATABASE_URL=sqlite+aiosqlite:///./tradepro_dev.db

# Redis URL (injected into backend container)
REDIS_URL=redis://localhost:6379/0

# JWT signing secret (shared reference for Docker)
JWT_SECRET=change-this-to-a-random-64-char-string

# CORS allowed origins (injected into backend container)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Log level (injected into backend container)
LOG_LEVEL=DEBUG
