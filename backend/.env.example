# PostgreSQL (Aiven) — required for production
DATABASE_URL=postgresql+asyncpg://avnadmin:YOUR_PASSWORD@YOUR_HOST.aivencloud.com:PORT/defaultdb?ssl=require

# Redis (optional, for rate limiting & caching)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,https://your-frontend.vercel.app

# Logging
LOG_LEVEL=INFO
