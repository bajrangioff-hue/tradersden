# ═══════════════════════════════════════════════════════════
# TradePro Backend — Environment Variable Reference
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp backend/.env.example backend/.env
# ═══════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
# Connection: async SQLAlchemy + asyncpg.
#   postgresql+asyncpg://user:password@host:port/dbname[?ssl=require]
# Unset → auto-detect local PostgreSQL → fallback to SQLite (dev only).
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tradepro

# SQLAlchemy connection pool settings
DB_POOL_SIZE=5              # Number of persistent connections
DB_MAX_OVERFLOW=0           # Extra connections beyond pool_size (0 = no overflow)
DB_ECHO=0                   # Log all SQL (1 = on, 0 = off)

# ── Redis ─────────────────────────────────────────────────────
# Used for: rate-limit counters, cached market snapshots, session store.
# Set to a remote URL in production (e.g. Upstash, Redis Cloud).
REDIS_URL=redis://localhost:6379/0

# ── JWT Authentication ───────────────────────────────────────
# Generate a strong secret:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-this-to-a-random-64-char-string

# Expiry durations
JWT_ACCESS_EXPIRE=15        # Access token lifetime (minutes)
JWT_REFRESH_EXPIRE=7        # Refresh token lifetime (days)

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated origins your frontend runs on.
# Set to * to allow all origins (disables credentialed requests).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,https://your-frontend.vercel.app

# ── Google OAuth ─────────────────────────────────────────────
# Credentials from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

# ── Market Data ──────────────────────────────────────────────
# Timeout (in seconds) when fetching data from Yahoo Finance.
YFINANCE_TIMEOUT=30

# ── Economic Calendar ───────────────────────────────────────
# API endpoint used for the economic calendar feed.
CALENDAR_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json
CALENDAR_TIMEOUT=15

# ── Logging ──────────────────────────────────────────────────
# Levels: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── API Metadata ────────────────────────────────────────────
APP_TITLE=TradePro Delivery System
APP_VERSION=3.0.0
API_V1_PREFIX=/api/v1
